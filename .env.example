# --- Frontend (Vite) — copy to .env.local ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Backend (Express) — copy to backend/.env ---
# Local: http://127.0.0.1:3000 | Vite proxies /api here (vite.config.ts)
PORT=3000
# Comma-separated browser origins allowed to call the API (CORS)
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin test bots: disabled in production unless explicitly true
ADMIN_BOT_API_ENABLED=false

# --- Vercel production SPA ---
# vercel.json rewrites /api/* to Render. Replace the host below with your
# Render Web Service URL (must match vercel.json "destination" host).
# Example: https://whacked-api.onrender.com

# --- Render Web Service (backend) ---
# Root directory: backend
# Build command: npm ci
# Start command: npm start
# Add the same env vars as backend/.env (SUPABASE_*, SERVICE_ROLE_KEY, etc.)
