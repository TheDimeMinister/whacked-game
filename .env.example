# --- Frontend (Vite) — copy to .env.local ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Optional: SSR/build-only; the app uses window.location.origin in the browser for auth redirects.
# VITE_SITE_URL=https://www.yourdomain.com

# --- Backend (Express) — copy to backend/.env ---
# Local: Vite proxies /api to PORT (vite.config.ts)
PORT=3000
# Comma-separated origins allowed to call /api (CORS). Set on Render in production.
# Include www and apex if you use both.
# Leave unset locally: dev allows http://localhost:5173 and http://127.0.0.1:5173 when NODE_ENV !== production.
# FRONTEND_ORIGIN=https://www.yourdomain.com,https://yourdomain.com

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin test bots: disabled in production unless explicitly true
ADMIN_BOT_API_ENABLED=false

# --- Vercel production SPA ---
# vercel.json rewrites /api/* to Render. The host must match the service's public
# URL in the dashboard (often fixed at service creation). Use a custom domain in
# Render if you want a short stable hostname instead of the default *.onrender.com.

# --- Render Web Service (backend) ---
# Root directory: backend
# Build command: npm ci
# Start command: npm start
# Add the same env vars as backend/.env (SUPABASE_*, SERVICE_ROLE_KEY, etc.)
